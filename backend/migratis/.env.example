DEBUG=True
USE_SQLITE=True

# PostgreSQL (only used when USE_SQLITE=False)
DB_NAME=migratis
DB_USER=migratis
DB_PASSWORD=change-me
DB_PORT=5432

# Email
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_SENDER=
EMAIL_MODERATOR=

# Stripe (only used when SUBSCRIPTION=True in frontend/src/settings.js)
STRIPE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET_KEY=

# Django
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=127.0.0.1,localhost,host.docker.internal
CORS_ORIGIN_WHITELIST=http://127.0.0.1:3002
FRONTEND_URL=http://127.0.0.1:3002
BACKEND_URL=http://127.0.0.1:8004
MEDIA_FULL_URL=http://127.0.0.1:8004/media/
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3002
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
NO_SUBSCRIPTION=True

# Migratis generator URL (must be reachable from inside the Docker container)
# On Linux/Mac with Docker: use host.docker.internal
MIGRATIS_BACKEND_URL=http://host.docker.internal:8000
